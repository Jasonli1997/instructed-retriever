# Databricks (required — used for vector search and optional reranker)
DATABRICKS_HOST=
DATABRICKS_CLIENT_ID=
DATABRICKS_CLIENT_SECRET=

# MLflow
MLFLOW_EXPERIMENT_ID=

# Observability
MLFLOW_TRACE_EXPORT_TO_UC=
OTEL_CATALOG=
OTEL_SCHEMA=
REDACT_PII=

# Models
# Use any LiteLLM-compatible model string, e.g.:
#   openai/gpt-4o
#   databricks/databricks-meta-llama-3-3-70b-instruct
#   anthropic/claude-3-5-sonnet-20241022
EMBEDDING_MODEL=
QUERY_REWRITER_MODEL=
ANSWER_GENERATOR_MODEL=
OPTIMIZED_PROMPT_PATH=  # Optional: path to optimized prompt JSON, e.g. artifacts/optimized_prompts/agent.json
SYSTEM_SPECS_PATH=      # Optional: path to system specs YAML, e.g. artifacts/system_specs.yaml
ENABLE_INSTRUCTED_RETRIEVAL=
ENABLE_LLM_RERANKING=
RERANKER_MODEL=

# Vector Search (Databricks)
VS_ENDPOINT=
VS_INDEX_NAME=

# Model Registry (optional — only needed for deployment)
MODEL_CATALOG=
MODEL_SCHEMA=
MODEL_NAME=
ENDPOINT_NAME=
